rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin email constant
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'bricenikiemagg@gmail.com';
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    // Users: can read/write their own doc, admin reads all
    match /users/{userId} {
      allow read: if isAdmin() || request.auth.uid == userId;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId || isAdmin();
      allow delete: if isAdmin();
    }

    // Events: everyone logged in can read, only admin writes
    match /events/{eventId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Cases: all logged users can read approved cases; authors/admin see all
    match /cases/{caseId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isAdmin() || (
        request.auth.uid == resource.data.authorId &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'authorId'])
      );
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if isLoggedIn();
        allow create: if isLoggedIn();
        allow delete: if isAdmin() || request.auth.uid == resource.data.authorId;
      }
    }

    // Labs: only admin writes
    match /labs/{labId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Invitations: only admin writes
    match /invitations/{invId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Confirmations: users create/read their own, admin reads all
    match /confirmations/{confId} {
      allow read: if isAdmin() || request.auth.uid == resource.data.userId;
      allow create: if isLoggedIn();
      allow update: if isAdmin() || request.auth.uid == resource.data.userId;
      allow delete: if isAdmin();
    }

    // Ads: everyone logged in reads, only admin writes
    match /ads/{adId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Custom medications: everyone reads, only admin writes
    match /medications/{medId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Noms commerciaux des médicaments (sous-collection)
    match /medications_noms/{medId}/noms/{nomId} {
      allow read: if isLoggedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
